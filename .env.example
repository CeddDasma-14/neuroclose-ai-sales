# ============================================================
# AI SALES AUTOMATION — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to version control
# ============================================================

# Claude API (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Twilio (console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Google Sheets (Google Cloud Console → Service Account)
GOOGLE_SHEET_ID=your-sheet-id-from-the-url
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# SendGrid (app.sendgrid.com)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=alerts@yourdomain.com

# Team Notifications
ACQUISITIONS_TEAM_EMAIL=team@yourdomain.com
MANAGER_EMAIL=manager@yourdomain.com

# Clerk Authentication (clerk.com — create a free account, then copy keys from your app dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/

# App Config
PORT=3000
NODE_ENV=development

# Next.js public base URL (used for lead deep-links in alerts)
NEXT_PUBLIC_BASE_URL=https://yourdomain.com

# Twilio webhook URL — set this in your Twilio console as the SMS webhook
# Points to the Next.js route: /api/webhook/sms
NEXT_PUBLIC_WEBHOOK_URL=https://yourdomain.com/api/webhook/sms

# Slack incoming webhook URL (optional — skip to disable Slack alerts)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/XXXX/XXXX

# Team email for hot lead alerts (optional — uses SendGrid when set)
TEAM_EMAIL=team@yourdomain.com

# LangFuse — AI observability (cloud.langfuse.com or self-hosted)
# Leave blank to disable tracing — all Claude calls still work normally
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# CORS — comma-separated list of allowed origins (leave empty for webhook-only / no browser clients)
ALLOWED_ORIGINS=

# API Cost Caps — max Claude API calls per day (0 = unlimited)
MAX_DAILY_CLASSIFY_CALLS=500
MAX_DAILY_REPLY_CALLS=500

# Outreach Settings
OUTREACH_BATCH_SIZE=50
OUTREACH_DELAY_MS=5000

# Business Context (used by Claude to craft personalized messages)
BUSINESS_NAME=Your Company Name
BUSINESS_TYPE=real estate wholesaling
SELLER_MOTIVATION_CONTEXT=We buy houses fast, cash, as-is, any condition
